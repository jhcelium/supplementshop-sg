const orgJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Supplement Shop Singapore",
  url: "https://supplementshop.neoi.jp/",
  description:
    "Non-commercial buying literacy for supplement shopping in Singapore.",
  inLanguage: "en-SG",
  areaServed: {
    "@type": "Country",
    name: "Singapore",
  },
  knowsAbout: [
    "supplement label reading",
    "health supplement retail channels in Singapore",
    "supplement seller verification",
    "proprietary blends",
    "GMP certification",
    "Health Sciences Authority Singapore regulations",
    "supplement shopping literacy",
  ],
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: ["h1", "main > p:first-of-type"],
  },
