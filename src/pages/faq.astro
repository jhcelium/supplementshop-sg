---
import BaseLayout from "../layouts/BaseLayout.astro";

const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Is buying supplements online safe in Singapore?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Online purchasing can be safe when sellers provide transparent ingredient lists, consistent product documentation, and realistic positioning without exaggerated claims.",
      },
    },
    {
      "@type": "Question",
      name: "Should I choose pharmacy over marketplace?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Pharmacies allow direct conversation with a pharmacist, while marketplaces offer wider selection. The choice depends on your need for consultation versus convenience.",
      },
    },
    {
      "@type": "Question",
      name: "How can I avoid overlapping ingredients?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Review labels carefully and compare nutrient amounts. Consider discussing combinations with a qualified clinician.",
      },
    },
    {
      "@type": "Question",
      name: "Are 'natural' supplements always better?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "'Natural' is a marketing term with variable meaning. Ingredient transparency matters more than labeling language.",
      },
    },
  ],
});
---
<BaseLayout
  title="FAQ | Supplement Shopping in Singapore"
  description="Frequently asked questions about buying supplements in Singapore."
  path="/faq"
>
  <script slot="head" type="application/ld+json" set:html={faqJsonLd}></script>

  <h1>Supplement Shopping Questions in Singapore</h1>

  <p class="disclaimer">
    General educational information only. Not medical advice.
  </p>

  <h2>Is buying supplements online safe in Singapore?</h2>
  <p>
    Online purchasing can be safe when sellers provide transparent ingredient lists, consistent product documentation, and realistic positioning without exaggerated claims.
  </p>

  <h2>Should I choose pharmacy over marketplace?</h2>
  <p>
    Pharmacies allow direct conversation with a pharmacist, while marketplaces offer wider selection. The choice depends on your need for consultation versus convenience.
  </p>

  <h2>How can I avoid overlapping ingredients?</h2>
  <p>
    Review labels carefully and compare nutrient amounts. Consider discussing combinations with a qualified clinician.
  </p>

  <figure class="infographic">
    <img
      src="/supplement-label-glossary.png"
      alt="Supplement Label Terms: A Quick Reference Glossary — explains measurement units (mg, mcg, IU, % DV), ingredient terms (active, inactive, proprietary blend, standardized extract), dosage terms (serving size, servings per container), and quality and safety terms (expiry date, batch number, GMP)."
      width="1024"
      loading="lazy"
    />
    <figcaption>
      Quick reference for common label terminology. When in doubt, consult a pharmacist or healthcare provider before purchasing.
    </figcaption>
  </figure>

  <h2>Are "natural" supplements always better?</h2>
  <p>
    "Natural" is a marketing term with variable meaning. Ingredient transparency matters more than labeling language.
  </p>

  <section class="cta">
    <a href="https://supplement.neoi.jp/en" target="_blank" rel="noopener">
      Visit Official Neoi Supplement Site →
    </a>
  </section>

  <p class="footer-note">
    Educational content only. Not medical or treatment advice.
  </p>
</BaseLayout>
