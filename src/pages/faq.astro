const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Where can I buy supplements in Singapore?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Supplements in Singapore are available through community pharmacies, hospital pharmacies, supermarkets, health stores, online marketplaces, and brand direct websites. Each channel offers different levels of pharmacist access, product range, and seller accountability.",
      },
    },
    {
      "@type": "Question",
      name: "How do I compare two supplement labels?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Compare the active ingredient list with specific amounts (mg, mcg, IU), serving size, servings per container, % Daily Value, inactive ingredients, and manufacturer details. Avoid comparing by packaging design or price alone.",
      },
    },
    {
      "@type": "Question",
      name: "What is a proprietary blend and why does it matter?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "A proprietary blend lists a group of ingredients under a single total weight without disclosing individual amounts. This limits transparency because you cannot determine how much of each ingredient is actually present per serving.",
      },
    },
    {
      "@type": "Question",
      name: "Pharmacy vs online: what should change in my checklist?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "At a pharmacy, a licensed pharmacist can help clarify label claims and check for interactions. Online, you need to verify seller legitimacy independently: check for consistent ingredient information across listings, confirm contact details, and assess return policies.",
      },
    },
