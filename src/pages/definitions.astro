---
import BaseLayout from "../layouts/BaseLayout.astro";
import { canonicalUrl, SITE_ORIGIN } from "../lib/siteUrls";

const pageDescription =
  "Plain-language definitions of supplement label and retail-shopping terms used on this site, for readers in Singapore.";

const definitionsUrl = canonicalUrl("/definitions");

const terms: { name: string; text: string }[] = [
  {
    name: "Proprietary blend",
    text: "A group of ingredients listed under one combined weight on a label, without individual amounts per ingredient. It limits how much you can infer about each component per serving.",
  },
  {
    name: "Active ingredient",
    text: "The substance named as providing the supplement’s stated nutritional or functional contribution, usually with an amount per serving (for example mg, mcg, or IU).",
  },
  {
    name: "Inactive ingredient",
    text: "Excipients such as fillers, binders, or coatings that give the product its physical form. They are listed separately from actives and may include allergens.",
  },
  {
    name: "% Daily Value (% DV)",
    text: "A reference percentage showing how much a nutrient in one serving contributes to a general daily intake benchmark. It is informational, not a personal requirement.",
  },
  {
    name: "Serving size",
    text: "The amount of product that counts as one serving on the label. All nutrient amounts refer to this serving unless the label states otherwise.",
  },
  {
    name: "GMP (Good Manufacturing Practice)",
    text: "A quality-system standard for how supplements are made and controlled. A GMP mention on packaging points to process standards, not a clinical outcome.",
  },
  {
    name: "Standardised extract",
    text: "A plant or botanical preparation processed so that a stated fraction of the material is a named compound class (for example a percentage of flavonoids), as declared on the label.",
  },
  {
    name: "Batch / lot number",
    text: "A code identifying a production run. It supports traceability if a quality notice or recall applies to specific batches.",
  },
];

const breadcrumbJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: SITE_ORIGIN },
    { "@type": "ListItem", position: 2, name: "Definitions", item: definitionsUrl },
  ],
});

const webPageJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Definitions | Supplement Shop Singapore",
  url: definitionsUrl,
  description: pageDescription,
  inLanguage: "en-SG",
  isPartOf: {
    "@type": "WebSite",
    name: "Supplement Shop Singapore",
    url: SITE_ORIGIN,
  },
});

const definedTermSetJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "DefinedTermSet",
  name: "Supplement label and retail definitions",
  description: pageDescription,
  inLanguage: "en-SG",
  url: definitionsUrl,
  hasDefinedTerm: terms.map((t) => ({
    "@type": "DefinedTerm",
    name: t.name,
    description: t.text,
  })),
});
---
<BaseLayout
  title="Definitions"
  description={pageDescription}
  path="/definitions"
  image="/supplement-label-glossary.png"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Definitions" }]}
>
  <script slot="head" type="application/ld+json" set:html={breadcrumbJsonLd}></script>
  <script slot="head" type="application/ld+json" set:html={webPageJsonLd}></script>
  <script slot="head" type="application/ld+json" set:html={definedTermSetJsonLd}></script>

  <h1>Definitions: labels & retail context</h1>

  <p class="disclaimer">
    General educational information only. Not medical advice. Terminology may differ by jurisdiction or product format.
  </p>

  <p class="lead">
    Short definitions for words and phrases used when reading supplement packaging or comparing retail channels in Singapore. They explain how language is used on this site; they are not product or store recommendations.
  </p>

  {terms.map((t) => (
    <section>
      <h2>{t.name}</h2>
      <p>{t.text}</p>
    </section>
  ))}

  <p class="footer-note">
    Educational content only. Not medical or treatment advice.
  </p>
</BaseLayout>
