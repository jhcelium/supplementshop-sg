---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadArticle, listArticleIds } from "../../lib/content";
import { canonicalUrl, SITE_ORIGIN } from "../../lib/siteUrls";

export async function getStaticPaths() {
  const ids = listArticleIds();
  return ids.map((id) => ({ params: { id } }));
}

const { id } = Astro.params;
const article = loadArticle(id!);
const fm = article.frontmatter;

const pageUrl = canonicalUrl(`/articles/${id}`);
const datePublished = fm.datePublished ?? "2025-11-01";
const dateModified = fm.dateModified ?? datePublished;
const author = fm.author ?? "Supplement Shop Singapore Editorial Team";

const articleJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  headline: fm.title,
  description: fm.description,
  url: pageUrl,
  inLanguage: "en-SG",
  datePublished,
  dateModified,
  mainEntityOfPage: { "@type": "WebPage", "@id": pageUrl },
  author: {
    "@type": "Organization",
    name: author,
    url: canonicalUrl("/about"),
  },
  publisher: {
    "@type": "Organization",
    name: "Supplement Shop Singapore",
    url: SITE_ORIGIN,
  },
  isPartOf: {
    "@type": "WebSite",
    name: "Supplement Shop Singapore",
    url: SITE_ORIGIN,
  },
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: ["h1", "article > p:first-of-type"],
  },
});

const breadcrumbJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: SITE_ORIGIN },
    { "@type": "ListItem", position: 2, name: fm.title, item: pageUrl },
  ],
});

const howToJsonLd = fm.howto
  ? JSON.stringify({
      "@context": "https://schema.org",
      "@type": "HowTo",
      name: fm.howto.name,
      description: fm.howto.description ?? fm.description,
      inLanguage: "en-SG",
      step: fm.howto.steps.map((s, i) => ({
        "@type": "HowToStep",
        position: i + 1,
        name: s.name,
        text: s.text,
      })),
    })
  : null;
---
<BaseLayout
  title={fm.title}
  description={fm.description}
  path={`/articles/${id}`}
  image="/supplement-label-guide.png"
  ogType="article"
  breadcrumbs={[{ label: "Home", href: "/" }, { label: fm.title }]}
>
  <script slot="head" type="application/ld+json" set:html={breadcrumbJsonLd}></script>
  <script slot="head" type="application/ld+json" set:html={articleJsonLd}></script>
  {howToJsonLd && (
    <script slot="head" type="application/ld+json" set:html={howToJsonLd}></script>
  )}

  <h1>{fm.title}</h1>
  <article set:html={article.html} />
  <p style="margin-top:32px"><a href="/">← Back to home</a></p>
</BaseLayout>
