---
import Seo from "../components/Seo.astro";
import site from "../../data/site.json";
interface Props {
  title?: string;
  description?: string;
  path?: string;
  image?: string;
  ogType?: string;
}
const { title, description, path, image, ogType } = Astro.props;
---
<!DOCTYPE html>
<html lang="en-SG">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Seo title={title} description={description} path={path} image={image} ogType={ogType} />
    <style>
      /* ── Tokens ──────────────────────────────────── */
      :root {
        --font: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        --text:          #1a1a1a;
        --text-muted:    #555;
        --text-faint:    #888;
        --border:        #d4d4d4;
        --border-strong: #1a1a1a;
        --bg:            #fff;
        --bg-tint:       #f7f7f7;
        --link:          #1c5fa8;
        --width:         960px;
        --prose:         68ch;
      }

      /* ── Reset ───────────────────────────────────── */
      *, *::before, *::after { box-sizing: border-box; }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: var(--font);
        font-size: 16px;
        line-height: 1.75;
        -webkit-font-smoothing: antialiased;
      }

      /* ── Shell ───────────────────────────────────── */
      header {
        border-bottom: 1px solid var(--border);
        padding: 14px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      main {
        max-width: var(--width);
        margin: 0 auto;
        padding: 44px 24px 72px;
      }

      footer {
        border-top: 1px solid var(--border);
        padding: 20px 24px;
        font-size: 13px;
        color: var(--text-muted);
        margin-top: 0;
      }
      footer > * + * { margin-top: 4px; }

      /* ── Navigation ──────────────────────────────── */
      nav {
        display: flex;
        align-items: center;
        gap: 20px;
      }
      nav a {
        font-size: 14px;
        color: var(--text);
        text-decoration: none;
        letter-spacing: 0.01em;
      }
      nav a:hover {
        text-decoration: underline;
        text-underline-offset: 3px;
      }

      /* ── Logo ────────────────────────────────────── */
      .header-logo {
        display: flex;
        align-items: center;
        flex-shrink: 0;
      }
      .header-logo img {
        height: 28px;
        width: auto;
        display: block;
      }

      /* ── Typography ──────────────────────────────── */
      h1 {
        font-size: 1.875rem;
        font-weight: 700;
        line-height: 1.2;
        letter-spacing: -0.022em;
        margin: 0 0 20px;
      }

      h2 {
        font-size: 1.125rem;
        font-weight: 600;
        line-height: 1.3;
        letter-spacing: -0.01em;
        margin: 44px 0 14px;
        padding-bottom: 8px;
        border-bottom: 1px solid var(--border);
      }

      h3 {
        font-size: 1rem;
        font-weight: 600;
        margin: 24px 0 8px;
      }

      p {
        margin: 0 0 16px;
        max-width: var(--prose);
      }

      strong { font-weight: 600; }

      /* ── Links ───────────────────────────────────── */
      a {
        color: var(--link);
        text-decoration: underline;
        text-underline-offset: 2px;
        text-decoration-thickness: 1px;
      }
      a:hover { color: var(--text); }

      /* ── Lists ───────────────────────────────────── */
      ul, ol {
        padding-left: 1.5rem;
        margin: 0 0 20px;
        max-width: var(--prose);
      }
      li { margin-bottom: 7px; line-height: 1.65; }

      /* ── Sections ────────────────────────────────── */
      section { margin-top: 4px; }

      /* ── Component: Disclaimer ───────────────────── */
      .disclaimer {
        border-left: 3px solid var(--border);
        background: var(--bg-tint);
        padding: 10px 14px;
        font-size: 13px;
        color: var(--text-muted);
        margin: 4px 0 32px;
        max-width: var(--prose);
      }

      /* ── Component: Lead ─────────────────────────── */
      .lead {
        font-size: 1.0625rem;
        color: #333;
        line-height: 1.7;
        margin-bottom: 28px;
        max-width: 62ch;
      }

      /* ── Component: Definition Block ─────────────── */
      .definition-block {
        border-left: 3px solid var(--border-strong);
        padding: 12px 16px;
        margin: 20px 0;
        background: var(--bg-tint);
        max-width: var(--prose);
      }
      .definition-block > .label {
        display: block;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        color: var(--text-muted);
        margin-bottom: 5px;
      }

      /* ── Component: Key Takeaway ─────────────────── */
      .key-takeaway {
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        padding: 14px 0;
        margin: 32px 0;
        font-size: 0.9375rem;
        max-width: var(--prose);
      }
      .key-takeaway::before {
        content: "Key point";
        display: block;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        color: var(--text-muted);
        margin-bottom: 7px;
      }

      /* ── Component: Cross Reference ──────────────── */
      .cross-reference {
        border: 1px solid var(--border);
        padding: 12px 16px;
        margin: 28px 0;
        font-size: 0.875rem;
        max-width: var(--prose);
      }
      .cross-reference::before {
        content: "See also";
        display: block;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        color: var(--text-muted);
        margin-bottom: 6px;
      }

      /* ── Component: Official site link ───────────── */
      .cta {
        margin: 40px 0 24px;
        padding-top: 20px;
        border-top: 1px solid var(--border);
      }
      .cta a {
        font-size: 14px;
        color: var(--text);
        text-decoration: none;
        letter-spacing: 0.01em;
      }
      .cta a:hover {
        text-decoration: underline;
        text-underline-offset: 3px;
      }

      /* ── Component: Footer note ──────────────────── */
      .footer-note {
        font-size: 12px;
        color: var(--text-faint);
        margin-top: 28px;
        max-width: 62ch;
      }

      /* ── Component: Infographic figure ───────────── */
      .infographic { margin: 40px 0; }
      .infographic img {
        width: 100%;
        height: auto;
        display: block;
        border: 1px solid var(--border);
      }
      .infographic figcaption {
        font-size: 12px;
        color: var(--text-faint);
        margin-top: 8px;
      }

      /* ── Responsive ──────────────────────────────── */
      @media (max-width: 640px) {
        h1    { font-size: 1.5rem; }
        h2    { font-size: 1.0625rem; margin-top: 36px; }
        main  { padding: 28px 16px 56px; }
        header, footer { padding-left: 16px; padding-right: 16px; }
      }
    </style>
    <slot name="head" />
  </head>
  <body>
    <header>
      <nav>
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/faq">FAQ</a>
      </nav>
      <a
        href="https://supplement.neoi.jp/en"
        target="_blank"
        rel="noopener noreferrer"
        class="header-logo"
        aria-label="Visit Official Neoi Supplement Site"
      >
        <img src="/neoi-logo.png" alt="supplement.neoi.jp logo" />
      </a>
    </header>
    <main><slot /></main>
    <footer>
      <div style="max-width:960px;margin:0 auto;">
        <div>{site.siteName}</div>
        <div>Educational content only. Not medical or treatment advice.</div>
        <div>
          <a href={site.officialSite} target="_blank" rel="noopener noreferrer">
            Official Neoi Site →
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>
